{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arto.app/schemas/keybindings-preset.schema.json",
  "title": "Arto Keybinding Preset",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "global": { "$ref": "#/$defs/bindings" },
    "content": { "$ref": "#/$defs/bindings" },
    "sidebar": { "$ref": "#/$defs/bindings" },
    "quickAccess": { "$ref": "#/$defs/bindings" },
    "rightSidebar": { "$ref": "#/$defs/bindings" },
    "search": { "$ref": "#/$defs/bindings" }
  },
  "$defs": {
    "bindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/keyAction" }
    },
    "keyAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "action"],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "pattern": "^[a-z]+(?:_[a-z]+)*(?:\\.[a-z]+(?:_[a-z]+)*)*$"
        }
      }
    }
  }
}
